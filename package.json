{
  "name": "clean-architecture-nestjs-practice",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "typeorm": "tsx node_modules/typeorm/cli.js -d src/shared/infrastructure/database/typeorm.config.ts",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "migration:generate": "npm run typeorm -- migration:generate",
    "migration:generate:help": "echo 'Usage: npm run typeorm -- migration:generate src/shared/infrastructure/database/migrations/YourMigrationName'"
  },
  "dependencies": {
    "@nestjs/common": "10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "10.4.15",
    "@nestjs/platform-express": "10.4.15",
    "@nestjs/typeorm": "^10.0.2",
    "@types/pg": "^8.11.10",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "joi": "^17.13.3",
    "pg": "^8.13.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "22.10.2",
    "tsx": "4.19.2",
    "typescript": "5.7.2"
  }
}
